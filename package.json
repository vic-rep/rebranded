{
  "name": "trusti-monorepo",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "pnpm --filter prototypes dev",
    "storybook": "pnpm --filter trusti-ui storybook",
    "build": "pnpm --filter trusti-ui build",
    "build:storybook": "pnpm --filter trusti-ui build-storybook"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=9"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "sharp", "lightningcss"]
  }
}
